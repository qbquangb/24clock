0071:  BTFSC  03.2
0072:  INCF   35,F
....................  
....................    // clear flag: trong CCS thường không bắt buộc vì runtime xử lý, 
....................    // nhưng ta đảm bảo bằng cách gọi clear_interrupt 
....................    clear_interrupt(INT_TIMER0); 
0073:  BCF    0B.2
.................... } 
